<Page x:Class="SmartProductivityManager.UI.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F8">

    <ScrollViewer>
        <StackPanel Margin="30,30,30,30" MaxWidth="700"
                    HorizontalAlignment="Left">

            <TextBlock Text="Reports" FontSize="26" FontWeight="Bold"
                       Foreground="#1E1E2E" Margin="0,0,0,24"/>

            <!-- Stats Grid -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White"
                        CornerRadius="12" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Completion Rate" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock x:Name="RateText" FontSize="28"
                                   FontWeight="Bold" Foreground="#7C3AED"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White"
                        CornerRadius="12" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="High Priority" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock x:Name="HighText" FontSize="28"
                                   FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Overdue" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock x:Name="OverdueText" FontSize="28"
                                   FontWeight="Bold" Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Category Breakdown -->
            <TextBlock Text="Tasks by Category" FontSize="18"
                       FontWeight="Bold" Foreground="#1E1E2E"
                       Margin="0,0,0,14"/>
            <ListView x:Name="CategoryList" BorderThickness="0"
                      Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10"
                                Padding="16,12" Margin="0,0,0,8" Width="600">
                            <Grid>
                                <TextBlock Text="{Binding Category}"
                                           FontSize="14" Foreground="#1E1E2E"/>
                                <TextBlock Text="{Binding Count}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#7C3AED"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>