<Page x:Class="SmartProductivityManager.UI.TaskListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0F0F1E">

    <Grid Margin="30,28,30,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="All Tasks" FontSize="26" FontWeight="Bold"
                       Foreground="#E5E7EB"/>
            <TextBlock x:Name="TaskCountText" FontSize="12"
                       Foreground="#6B7280" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search + Filter Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#151528"
                    BorderBrush="#ffffff15" BorderThickness="1"
                    CornerRadius="8">
                <TextBox x:Name="SearchBox"
                         Background="Transparent"
                         Foreground="#E5E7EB"
                         CaretBrush="#C084FC"
                         BorderThickness="0"
                         FontSize="13" Height="40"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
            </Border>

            <ComboBox Grid.Column="2" x:Name="FilterBox"
                      Height="40" FontSize="12"
                      Background="#151528"
                      Foreground="#E5E7EB"
                      BorderBrush="#ffffff15"
                      SelectionChanged="FilterBox_Changed">
                <ComboBoxItem Content="All Status" IsSelected="True"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="In Progress"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>

            <Button Grid.Column="4" Content="Refresh"
                    Click="Refresh_Click" Height="40"
                    Style="{StaticResource PrimaryBtn}"/>
        </Grid>

        <!-- Tasks List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <ListView x:Name="TasksList"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#151528"
                                BorderBrush="#ffffff0D"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <!-- Task Info -->
                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#E5E7EB"/>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Category}"
                                                   FontSize="11"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text=" · "
                                                   FontSize="11"
                                                   Foreground="#374151"/>
                                        <TextBlock Text="{Binding DueDate,
                                                   StringFormat='Due {0:dd MMM yyyy}'}"
                                                   FontSize="11"
                                                   Foreground="#6B7280"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Priority Badge -->
                                <Border Grid.Column="1"
                                        Background="{Binding PriorityBg}"
                                        CornerRadius="6" Padding="10,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Priority}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding PriorityColor}"/>
                                </Border>

                                <!-- Status Badge -->
                                <Border Grid.Column="2"
                                        Background="{Binding StatusBg}"
                                        CornerRadius="6" Padding="10,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding StatusColor}"/>
                                </Border>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Button Content="▶ Start"
                                            Tag="{Binding Id}"
                                            Click="MarkInProgress_Click"
                                            Height="30" Margin="0,0,6,0"
                                            Padding="10,0"
                                            Background="#3B82F620"
                                            Foreground="#93C5FD"
                                            BorderBrush="#3B82F640"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="✓ Done"
                                            Tag="{Binding Id}"
                                            Click="MarkComplete_Click"
                                            Height="30" Margin="0,0,6,0"
                                            Padding="10,0"
                                            Background="#10B98120"
                                            Foreground="#34D399"
                                            BorderBrush="#10B98140"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="🗑"
                                            Tag="{Binding Id}"
                                            Click="Delete_Click"
                                            Height="30" Width="30"
                                            Background="#EF444420"
                                            Foreground="#F87171"
                                            BorderBrush="#EF444440"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>