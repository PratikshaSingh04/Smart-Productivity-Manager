<Window x:Class="SmartProductivityManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Productivity Manager"
        Height="720" Width="1150"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#0A0A1A"
                BorderBrush="#ffffff0A"
                BorderThickness="0,0,1,0">
            <StackPanel>
                <!-- Logo -->
                <StackPanel Margin="20,28,20,24">
                    <Border Width="38" Height="38"
                            CornerRadius="10"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C63FF" Offset="0"/>
                                <GradientStop Color="#C084FC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="SP" Foreground="White"
                                   FontWeight="Bold" FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Smart PM" Foreground="White"
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Productivity Manager"
                               Foreground="#4B5563" FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#ffffff0A" Margin="0,0,0,16"/>

                <TextBlock Text="MENU" Foreground="#374151"
                        FontSize="10" FontWeight="Bold"
                        Margin="20,0,0,10"/>

                <Button Content="  Dashboard"
                        Click="ShowDashboard"
                        Style="{StaticResource NavButton}"
                        Foreground="#C084FC"
                        Tag="active"/>
                <Button Content="  All Tasks"
                        Click="ShowTaskList"
                        Style="{StaticResource NavButton}"/>
                <Button Content="  Add Task"
                        Click="ShowAddTask"
                        Style="{StaticResource NavButton}"/>
                <Button Content="  Kanban Board"
                        Click="ShowKanban"
                        Style="{StaticResource NavButton}"/>
                <Button Content="  Reports"
                        Click="ShowReports"
                        Style="{StaticResource NavButton}"/>

                <!-- Bottom info -->
                <StackPanel VerticalAlignment="Bottom" Margin="20,40,20,24">
                    <Rectangle Height="1" Fill="#ffffff0A" Margin="0,0,0,16"/>
                    <TextBlock Text="v1.0 — .NET 10" Foreground="#374151"
                               FontSize="10"/>
                    <TextBlock Text="Group Project 2026" Foreground="#374151"
                               FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Border Grid.Column="1" Background="#0F0F1E">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Border>
    </Grid>
</Window>