<Page x:Class="SmartProductivityManager.UI.KanbanView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0F0F1E">

    <Grid Margin="30,28,30,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Kanban Board" FontSize="26"
                           FontWeight="Bold" Foreground="#E5E7EB"/>
                <TextBlock Text="Move tasks across columns to update their status live"
                           FontSize="12" Foreground="#6B7280" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="↺  Refresh"
                    Click="Refresh_Click" Height="38"
                    Style="{StaticResource PrimaryBtn}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Kanban Columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PENDING Column -->
            <Border Grid.Column="0" Background="#151528"
                    BorderBrush="#F59E0B25" BorderThickness="1"
                    CornerRadius="14">
                <Grid Margin="14,14,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="0,0,0,14">
                        <Border Background="#F59E0B20" CornerRadius="6"
                                Padding="10,5">
                            <TextBlock Text="PENDING" FontSize="11"
                                       FontWeight="Bold" Foreground="#FCD34D"/>
                        </Border>
                        <Border x:Name="PendingCount"
                                Background="#F59E0B15" CornerRadius="10"
                                Padding="8,4" Margin="8,0,0,0">
                            <TextBlock x:Name="PendingCountText"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#F59E0B"/>
                        </Border>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PendingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E35"
                                            BorderBrush="#ffffff08"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,10"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#E5E7EB"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11" Foreground="#6B7280"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding DueDate,
                                                       StringFormat='Due: {0:dd MMM}'}"
                                                       FontSize="11" Foreground="#4B5563"
                                                       Margin="0,2,0,8"/>
                                            <Border Background="{Binding PriorityBg}"
                                                    CornerRadius="4" Padding="6,3"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Priority}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding PriorityColor}"/>
                                            </Border>
                                            <Button Content="▶  Move to In Progress"
                                                    Tag="{Binding Id}"
                                                    Click="MoveToInProgress_Click"
                                                    Height="28" FontSize="11"
                                                    Background="#3B82F620"
                                                    Foreground="#93C5FD"
                                                    BorderBrush="#3B82F640"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- IN PROGRESS Column -->
            <Border Grid.Column="2" Background="#151528"
                    BorderBrush="#3B82F625" BorderThickness="1"
                    CornerRadius="14">
                <Grid Margin="14,14,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="0,0,0,14">
                        <Border Background="#3B82F620" CornerRadius="6"
                                Padding="10,5">
                            <TextBlock Text="IN PROGRESS" FontSize="11"
                                       FontWeight="Bold" Foreground="#93C5FD"/>
                        </Border>
                        <Border Background="#3B82F615" CornerRadius="10"
                                Padding="8,4" Margin="8,0,0,0">
                            <TextBlock x:Name="InProgressCountText"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#3B82F6"/>
                        </Border>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="InProgressList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E35"
                                            BorderBrush="#ffffff08"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,10"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#E5E7EB"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11" Foreground="#6B7280"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding DueDate,
                                                       StringFormat='Due: {0:dd MMM}'}"
                                                       FontSize="11" Foreground="#4B5563"
                                                       Margin="0,2,0,8"/>
                                            <Border Background="{Binding PriorityBg}"
                                                    CornerRadius="4" Padding="6,3"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Priority}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding PriorityColor}"/>
                                            </Border>
                                            <Button Content="✓  Mark as Done"
                                                    Tag="{Binding Id}"
                                                    Click="MarkDone_Click"
                                                    Height="28" FontSize="11"
                                                    Background="#10B98120"
                                                    Foreground="#34D399"
                                                    BorderBrush="#10B98140"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- COMPLETED Column -->
            <Border Grid.Column="4" Background="#151528"
                    BorderBrush="#10B98125" BorderThickness="1"
                    CornerRadius="14">
                <Grid Margin="14,14,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="0,0,0,14">
                        <Border Background="#10B98120" CornerRadius="6"
                                Padding="10,5">
                            <TextBlock Text="COMPLETED" FontSize="11"
                                       FontWeight="Bold" Foreground="#34D399"/>
                        </Border>
                        <Border Background="#10B98115" CornerRadius="10"
                                Padding="8,4" Margin="8,0,0,0">
                            <TextBlock x:Name="CompletedCountText"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#10B981"/>
                        </Border>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CompletedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E35"
                                            BorderBrush="#ffffff08"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,10"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#6B7280"
                                                       TextWrapping="Wrap"
                                                       TextDecorations="Strikethrough"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11" Foreground="#4B5563"
                                                       Margin="0,4,0,4"/>
                                            <Border Background="#10B98115"
                                                    CornerRadius="4" Padding="6,3"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="✓ Completed"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#34D399"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>