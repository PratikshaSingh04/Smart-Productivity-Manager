<Page x:Class="SmartProductivityManager.UI.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0F0F1E">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,28,30,30">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="26"
                               FontWeight="Bold" Foreground="#E5E7EB"/>
                    <TextBlock x:Name="DateText" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#151528"
                        BorderBrush="#ffffff10"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="Live" Foreground="#10B981"
                               FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Stats Cards -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="14"
                        Margin="0,0,10,0" Padding="18,16"
                        BorderThickness="1" BorderBrush="#6C63FF30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a1a3e" Offset="0"/>
                            <GradientStop Color="#252550" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="TOTAL TASKS" FontSize="10"
                                   Foreground="#6B7280" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalCount" FontSize="36"
                                   FontWeight="Bold" Foreground="#A78BFA"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="14"
                        Margin="0,0,10,0" Padding="18,16"
                        BorderThickness="1" BorderBrush="#10B98130">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0d2e1a" Offset="0"/>
                            <GradientStop Color="#0d3d22" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="COMPLETED" FontSize="10"
                                   Foreground="#6B7280" FontWeight="Bold"/>
                        <TextBlock x:Name="CompletedCount" FontSize="36"
                                   FontWeight="Bold" Foreground="#34D399"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="14"
                        Margin="0,0,10,0" Padding="18,16"
                        BorderThickness="1" BorderBrush="#F59E0B30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2d1f00" Offset="0"/>
                            <GradientStop Color="#3d2a00" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="PENDING" FontSize="10"
                                   Foreground="#6B7280" FontWeight="Bold"/>
                        <TextBlock x:Name="PendingCount" FontSize="36"
                                   FontWeight="Bold" Foreground="#FCD34D"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" CornerRadius="14"
                        Padding="18,16"
                        BorderThickness="1" BorderBrush="#EF444430">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2d0d0d" Offset="0"/>
                            <GradientStop Color="#3d1111" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="OVERDUE" FontSize="10"
                                   Foreground="#6B7280" FontWeight="Bold"/>
                        <TextBlock x:Name="OverdueCount" FontSize="36"
                                   FontWeight="Bold" Foreground="#F87171"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Smart Suggestion -->
            <Border CornerRadius="12" Padding="18,14"
                    Margin="0,0,0,24"
                    BorderThickness="1" BorderBrush="#6C63FF35">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1a103d" Offset="0"/>
                        <GradientStop Color="#20123d" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal" >
                    <Border Width="32" Height="32" CornerRadius="8"
                            Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C63FF" Offset="0"/>
                                <GradientStop Color="#C084FC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="✦" Foreground="White" FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Smart Suggestion"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#A78BFA"/>
                        <TextBlock x:Name="SuggestionText"
                                   FontSize="12" Foreground="#C4B5FD"
                                   Margin="0,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recent Tasks -->
            <TextBlock Text="RECENT TASKS" FontSize="11"
                       FontWeight="Bold" Foreground="#4B5563"
                       Margin="0,0,0,12"/>

            <ListView x:Name="RecentTasksList"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#151528"
                                BorderBrush="#ffffff0D"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16,12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E5E7EB"/>
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="11" Foreground="#6B7280"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DueDate, StringFormat='Due: {0:dd MMM}'}"
                                           FontSize="11" Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="2"
                                        Background="{Binding PriorityBg}"
                                        CornerRadius="6" Padding="10,4"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Priority}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding PriorityColor}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>