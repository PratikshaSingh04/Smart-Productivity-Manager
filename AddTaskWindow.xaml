<Page x:Class="SmartProductivityManager.UI.AddTaskWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0F0F1E">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,32" MaxWidth="580"
                    HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Add New Task"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#E5E7EB" Margin="0,0,0,6"/>
            <TextBlock Text="Fill in the details below to create a new task"
                       FontSize="13" Foreground="#6B7280"
                       Margin="0,0,0,32"/>

            <!-- Task Title -->
            <TextBlock Text="TASK TITLE" FontSize="11"
                       FontWeight="Bold" Foreground="#6B7280"
                       Margin="0,0,0,8"/>
            <Border Background="#151528" BorderBrush="#ffffff18"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,0,20">
                <TextBox x:Name="TitleBox"
                         Background="Transparent"
                         Foreground="#E5E7EB"
                         CaretBrush="#C084FC"
                         BorderThickness="0"
                         FontSize="13" Height="42"
                         Padding="14,0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <!-- Description -->
            <TextBlock Text="DESCRIPTION" FontSize="11"
                       FontWeight="Bold" Foreground="#6B7280"
                       Margin="0,0,0,8"/>
            <Border Background="#151528" BorderBrush="#ffffff18"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,0,20">
                <TextBox x:Name="DescBox"
                         Background="Transparent"
                         Foreground="#E5E7EB"
                         CaretBrush="#C084FC"
                         BorderThickness="0"
                         FontSize="13" Height="90"
                         Padding="14,10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"/>
            </Border>

            <!-- Category + Due Date Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Category -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CATEGORY" FontSize="11"
                               FontWeight="Bold" Foreground="#6B7280"
                               Margin="0,0,0,8"/>
                    <Border Background="#151528" BorderBrush="#ffffff18"
                            BorderThickness="1" CornerRadius="8">
                        <ComboBox x:Name="CategoryBox"
                                  Background="Transparent"
                                  Foreground="#E5E7EB"
                                  BorderThickness="0"
                                  FontSize="13" Height="42">
                            <ComboBoxItem Content="General" IsSelected="True"/>
                            <ComboBoxItem Content="Work"/>
                            <ComboBoxItem Content="Study"/>
                            <ComboBoxItem Content="Personal"/>
                            <ComboBoxItem Content="Health"/>
                            <ComboBoxItem Content="Finance"/>
                        </ComboBox>
                    </Border>
                </StackPanel>

                <!-- Due Date -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="DUE DATE" FontSize="11"
                               FontWeight="Bold" Foreground="#6B7280"
                               Margin="0,0,0,8"/>
                    <Border Background="#151528" BorderBrush="#ffffff18"
                            BorderThickness="1" CornerRadius="8">
                        <DatePicker x:Name="DueDatePicker"
                                    Background="Transparent"
                                    Foreground="#E5E7EB"
                                    BorderThickness="0"
                                    FontSize="13" Height="42"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Auto Priority Notice -->
            <Border Background="#F59E0B12"
                    BorderBrush="#F59E0B30"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,12"
                    Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="14"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Smart Auto-Priority"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#FCD34D"/>
                        <TextBlock Text="Due in 1 day = High  ·  3 days = Medium  ·  3+ days = Low"
                                   FontSize="11" Foreground="#6B7280"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Add Button -->
            <Button Content="+ Add Task"
                    Click="AddTask_Click"
                    Height="48" FontSize="14"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Color="#6C63FF" Offset="0"/>
                                    <GradientStop Color="#C084FC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="White"
                                              TextElement.FontSize="14"
                                              TextElement.FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Result Message -->
            <TextBlock x:Name="ResultMsg"
                       FontSize="13"
                       Margin="0,14,0,0"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</Page>